<html>
<head>
<meta charset="UTF-8">
<title>NetBlocker — אזור אישי</title>
<HTA:APPLICATION
  APPLICATIONNAME="NetBlocker Dashboard"
  BORDER="thin"
  CAPTION="yes"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  WINDOWSTATE="maximize"
/>
<style>
* { box-sizing:border-box; margin:0; padding:0; font-family:'Segoe UI',Arial,sans-serif; }
body { background:#0f172a; color:#e2e8f0; direction:rtl; display:flex; height:100vh; overflow:hidden; }

/* SIDEBAR */
.sidebar { width:220px; background:#0c1426; border-left:1px solid #1e293b; display:flex; flex-direction:column; padding:20px 0; flex-shrink:0; }
.brand { padding:0 20px 24px; border-bottom:1px solid #1e293b; }
.brand-icon { font-size:28px; }
.brand-name { font-size:1.1rem; font-weight:800; color:#60a5fa; }
.brand-ver { font-size:0.7rem; color:#475569; }
.nav { flex:1; padding:16px 0; }
.nav-item { display:flex; align-items:center; gap:10px; padding:10px 20px; color:#94a3b8; font-size:0.88rem; cursor:pointer; transition:all 0.15s; border-right:3px solid transparent; }
.nav-item:hover { background:#1e293b; color:#e2e8f0; }
.nav-item.active { background:#1e3a5f; color:#60a5fa; border-right-color:#60a5fa; }
.nav-icon { font-size:16px; }
.sidebar-footer { padding:16px 20px; border-top:1px solid #1e293b; }
.user-box { display:flex; align-items:center; gap:10px; }
.user-avatar { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#2563eb,#7c3aed); display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:white; }
.user-name { font-size:0.85rem; font-weight:600; }
.user-profile { font-size:0.72rem; color:#64748b; }

/* MAIN */
.main { flex:1; display:flex; flex-direction:column; overflow:hidden; }
.topbar { background:#0c1426; border-bottom:1px solid #1e293b; padding:14px 24px; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.topbar-title { font-size:1rem; font-weight:700; color:#e2e8f0; }
.topbar-actions { display:flex; gap:8px; }
.btn { border:none; border-radius:8px; padding:8px 16px; font-size:0.82rem; cursor:pointer; font-family:inherit; font-weight:600; transition:opacity 0.2s; }
.btn:hover { opacity:0.85; }
.btn-blue { background:#2563eb; color:white; }
.btn-green { background:#16a34a; color:white; }
.btn-red { background:#dc2626; color:white; }
.btn-gray { background:#334155; color:#e2e8f0; }

.content { flex:1; overflow-y:auto; padding:24px; }
.page { display:none; }
.page.active { display:block; }

/* CARDS */
.card { background:#1e293b; border:1px solid #334155; border-radius:12px; padding:20px; margin-bottom:16px; }
.card-title { font-size:0.88rem; color:#94a3b8; margin-bottom:4px; }
.card-value { font-size:1.6rem; font-weight:800; color:#e2e8f0; }
.card-sub { font-size:0.75rem; color:#64748b; margin-top:2px; }

.stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px; }

/* STATUS */
.status-badge { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:99px; font-size:0.78rem; font-weight:600; }
.status-badge.active { background:#14532d; color:#86efac; }
.status-badge.inactive { background:#450a0a; color:#fca5a5; }
.status-dot { width:6px; height:6px; border-radius:50%; }
.active .status-dot { background:#22c55e; }
.inactive .status-dot { background:#ef4444; }

/* FORM */
.field { margin-bottom:14px; }
.field label { display:block; font-size:0.82rem; color:#94a3b8; margin-bottom:4px; }
.field input, .field textarea { width:100%; background:#0f172a; border:1.5px solid #334155; color:#e2e8f0; border-radius:8px; padding:10px 14px; font-size:0.9rem; outline:none; font-family:inherit; }
.field input:focus, .field textarea:focus { border-color:#60a5fa; }
.field textarea { height:80px; resize:vertical; }

/* TABLE */
table { width:100%; border-collapse:collapse; font-size:0.85rem; }
th { text-align:right; padding:10px 12px; color:#64748b; font-weight:600; border-bottom:1px solid #334155; font-size:0.78rem; }
td { padding:10px 12px; border-bottom:1px solid #1e293b; color:#cbd5e1; }
tr:hover td { background:#1e293b22; }

/* ALERT */
.alert { padding:12px 16px; border-radius:8px; font-size:0.85rem; margin-bottom:14px; }
.alert.info { background:#1e3a5f; border:1px solid #3b82f6; color:#93c5fd; }
.alert.success { background:#14532d; border:1px solid #22c55e; color:#86efac; }
.alert.warn { background:#451a03; border:1px solid #f59e0b; color:#fcd34d; }

/* PROGRESS BAR */
.mini-bar { background:#0f172a; border-radius:99px; height:6px; overflow:hidden; margin-top:6px; }
.mini-fill { height:100%; background:linear-gradient(90deg,#2563eb,#7c3aed); border-radius:99px; transition:width 0.4s; }

/* UPDATE */
.update-card { background:linear-gradient(135deg,#1e3a5f,#1e1b4b); border:1px solid #3b82f6; border-radius:12px; padding:20px; margin-bottom:16px; display:flex; align-items:center; justify-content:space-between; }
.update-info h3 { color:#93c5fd; font-size:0.95rem; }
.update-info p { color:#64748b; font-size:0.8rem; margin-top:3px; }
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="brand">
    <div class="brand-icon">🛡️</div>
    <div class="brand-name">NetBlocker</div>
    <div class="brand-ver">v1.0.0</div>
  </div>
  <div class="nav">
    <div class="nav-item active" onclick="nav('home',this)"><span class="nav-icon">🏠</span> ראשי</div>
    <div class="nav-item" onclick="nav('request',this)"><span class="nav-icon">📩</span> בקשת פתיחה</div>
    <div class="nav-item" onclick="nav('sites',this)"><span class="nav-icon">🌐</span> רשימת אתרים</div>
    <div class="nav-item" onclick="nav('uninstall',this)"><span class="nav-icon">🗑️</span> הסרת תוכנה</div>
  </div>
  <div class="sidebar-footer">
    <div class="user-box">
      <div class="user-avatar" id="avatarLetter">?</div>
      <div>
        <div class="user-name" id="sidebarName">טוען...</div>
        <div class="user-profile" id="sidebarProfile">פרופיל: default</div>
      </div>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-title" id="pageTitle">ראשי</div>
    <div class="topbar-actions">
      <button class="btn btn-blue" onclick="refresh()">🔄 ריענון</button>
    </div>
  </div>

  <div class="content">

    <!-- HOME -->
    <div class="page active" id="page-home">
      <div id="updateBanner" style="display:none" class="update-card">
        <div class="update-info">
          <h3>🆕 עדכון זמין!</h3>
          <p id="updateVer">גרסה חדשה זמינה מהמנהל</p>
        </div>
        <button class="btn btn-blue" onclick="doUpdate()">עדכן עכשיו</button>
      </div>

      <div class="stats-grid">
        <div class="card">
          <div class="card-title">סטטוס מערכת</div>
          <div style="margin-top:8px"><span class="status-badge active"><span class="status-dot"></span>פעיל</span></div>
        </div>
        <div class="card">
          <div class="card-title">אתרים חסומים</div>
          <div class="card-value" id="blockedCount">—</div>
          <div class="card-sub">בפרופיל הנוכחי</div>
        </div>
        <div class="card">
          <div class="card-title">עדכון אחרון</div>
          <div class="card-value" style="font-size:1rem" id="lastUpdate">—</div>
        </div>
      </div>

      <div class="card">
        <h3 style="color:#93c5fd;margin-bottom:12px;font-size:0.95rem">פרטי משתמש</h3>
        <table>
          <tr><td style="color:#64748b;width:120px">שם</td><td id="infoName">—</td></tr>
          <tr><td style="color:#64748b">טלפון</td><td id="infoPhone">—</td></tr>
          <tr><td style="color:#64748b">אימייל</td><td id="infoEmail">—</td></tr>
          <tr><td style="color:#64748b">פרופיל</td><td id="infoProfile">—</td></tr>
        </table>
      </div>
    </div>

    <!-- REQUEST -->
    <div class="page" id="page-request">
      <div class="card">
        <h3 style="color:#93c5fd;margin-bottom:14px;font-size:0.95rem">📩 בקשת פתיחת אתר</h3>
        <div class="alert info">הבקשה תישלח למנהל המערכת לאישור. תקבל עדכון בהמשך.</div>
        <div class="field">
          <label>כתובת האתר</label>
          <input id="reqUrl" placeholder="https://www.example.com">
        </div>
        <div class="field">
          <label>סיבת הבקשה</label>
          <textarea id="reqReason" placeholder="תאר מדוע אתה צריך גישה לאתר זה..."></textarea>
        </div>
        <button class="btn btn-blue" onclick="sendRequest()">שלח בקשה →</button>
        <div id="reqStatus" style="margin-top:12px;font-size:0.85rem;color:#86efac;display:none">✅ הבקשה נשלחה! המנהל יצור איתך קשר.</div>
      </div>
    </div>

    <!-- SITES -->
    <div class="page" id="page-sites">
      <div class="topbar-actions" style="margin-bottom:14px">
        <button class="btn btn-blue" onclick="loadSiteList()">🔄 ריענון רשימה</button>
      </div>
      <div class="card">
        <h3 style="color:#93c5fd;margin-bottom:14px;font-size:0.95rem">🌐 אתרים חסומים בפרופיל שלי</h3>
        <div id="siteListContent">
          <div style="color:#64748b;text-align:center;padding:24px">לחץ ריענון לטעינה...</div>
        </div>
      </div>
    </div>

    <!-- UNINSTALL -->
    <div class="page" id="page-uninstall">
      <div class="card">
        <h3 style="color:#fca5a5;margin-bottom:14px;font-size:0.95rem">🗑️ הסרת תוכנה</h3>
        <div class="alert warn">הסרת התוכנה דורשת אישור מנהל המערכת. הבקשה תישלח אוטומטית.</div>
        <div class="field">
          <label>סיבת ההסרה (אופציונלי)</label>
          <textarea id="uninstReason" placeholder="מדוע אתה מבקש להסיר את התוכנה?"></textarea>
        </div>
        <button class="btn btn-red" onclick="requestUninstall()">שלח בקשת הסרה</button>
        <div id="uninstStatus" style="margin-top:14px;display:none"></div>
      </div>

      <div class="card" id="uninstApprovedCard" style="display:none">
        <div class="alert success">✅ הבקשה אושרה על ידי המנהל! ניתן להסיר עכשיו.</div>
        <button class="btn btn-red" onclick="doUninstall()">הסר עכשיו</button>
      </div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<script language="VBScript">
Function VBRead(path)
  Dim fso, f
  Set fso = CreateObject("Scripting.FileSystemObject")
  If fso.FileExists(path) Then
    Set f = fso.OpenTextFile(path, 1, False, -1)
    VBRead = f.ReadAll
    f.Close
  Else
    VBRead = ""
  End If
End Function

Function VBRun(cmd)
  Dim s
  Set s = CreateObject("WScript.Shell")
  s.Run "powershell -WindowStyle Hidden -ExecutionPolicy Bypass -Command " & Chr(34) & cmd & Chr(34), 0, True
End Function

Function VBShell(cmd)
  Dim s
  Set s = CreateObject("WScript.Shell")
  s.Run cmd, 0, True
End Function
</script>

<script language="JavaScript">
var CFG = {
  installDir: "C:\\NetBlocker",
  githubBase: "https://meny0583285502.github.io/LAVAN",
  adminEmail: "6183444@gmail.com",
  ejsService: "YOUR_SERVICE_ID",
  ejsTplReq:  "template_request",
  ejsTplUninst:"template_uninstall",
  ejsKey:     "YOUR_PUBLIC_KEY"
};
var user = {name:"",phone:"",email:"",profile:"default"};

window.onload = function() {
  loadUser();
  checkUpdate();
};

function loadUser() {
  try {
    var raw = VBRead(CFG.installDir + "\\user.json");
    if(raw) {
      user = JSON.parse(raw);
      document.getElementById('avatarLetter').innerText = user.name ? user.name.charAt(0) : "?";
      document.getElementById('sidebarName').innerText = user.name || "משתמש";
      document.getElementById('sidebarProfile').innerText = "פרופיל: " + (user.profile||"default");
      document.getElementById('infoName').innerText = user.name;
      document.getElementById('infoPhone').innerText = user.phone||"—";
      document.getElementById('infoEmail').innerText = user.email||"—";
      document.getElementById('infoProfile').innerText = user.profile||"default";
    }
  } catch(e){}

  // עדכון אחרון מ-profile JSON
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    xhr.open("GET", CFG.githubBase+"/profiles/"+(user.profile||"default")+".json", false);
    xhr.send();
    if(xhr.status===200) {
      var pdata = JSON.parse(xhr.responseText);
      var blocked = (pdata.blocked_domains||[]).length + (pdata.blocked_apps_domains||[]).length;
      document.getElementById('blockedCount').innerText = blocked;
      document.getElementById('lastUpdate').innerText = pdata.last_updated||"—";
    }
  } catch(e){}
}

function checkUpdate() {
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    xhr.open("GET", CFG.githubBase+"/version.json", false);
    xhr.send();
    if(xhr.status===200) {
      var v = JSON.parse(xhr.responseText);
      if(v.version && v.version !== "1.0.0") {
        document.getElementById('updateBanner').style.display='flex';
        document.getElementById('updateVer').innerText = "גרסה "+v.version+" זמינה — "+v.notes;
      }
    }
  } catch(e){}
}

function doUpdate() {
  if(confirm("האם לעדכן עכשיו? המחשב לא יהיה חסום למשך כמה שניות.")) {
    try {
      var sh = new ActiveXObject("WScript.Shell");
      sh.Run('powershell -WindowStyle Hidden -ExecutionPolicy Bypass -File "'+CFG.installDir+'\\startup.ps1"', 0, true);
    } catch(e){}
    alert("✅ עדכון הושלם! הרשימה עודכנה.");
    document.getElementById('updateBanner').style.display='none';
  }
}

function nav(page, el) {
  document.querySelectorAll('.nav-item').forEach(function(i){ i.classList.remove('active'); });
  el.classList.add('active');
  document.querySelectorAll('.page').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('page-'+page).classList.add('active');
  var titles = {home:'ראשי',request:'בקשת פתיחה',sites:'רשימת אתרים',uninstall:'הסרת תוכנה'};
  document.getElementById('pageTitle').innerText = titles[page]||page;
}

function refresh() {
  loadUser();
  checkUpdate();
  alert("✅ המידע עודכן!");
}

function sendRequest() {
  var url = document.getElementById('reqUrl').value;
  var reason = document.getElementById('reqReason').value;
  if(!url) { alert("נא להכניס כתובת אתר"); return; }
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    var params = {
      service_id: CFG.ejsService,
      template_id: CFG.ejsTplReq,
      user_id: CFG.ejsKey,
      template_params: {
        to_email: CFG.adminEmail,
        subject: "בקשת פתיחה: " + url,
        user_name: user.name,
        user_email: user.email,
        user_phone: user.phone,
        profile: user.profile,
        requested_url: url,
        reason: reason,
        request_time: new Date().toLocaleString('he-IL')
      }
    };
    xhr.open("POST","https://api.emailjs.com/api/v1.0/email/send",false);
    xhr.setRequestHeader("Content-Type","application/json");
    xhr.send(JSON.stringify(params));
  } catch(e){}
  document.getElementById('reqStatus').style.display='block';
  document.getElementById('reqUrl').value='';
  document.getElementById('reqReason').value='';
}

function loadSiteList() {
  var el = document.getElementById('siteListContent');
  el.innerHTML = '<div style="color:#64748b;text-align:center;padding:16px">טוען...</div>';
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    xhr.open("GET", CFG.githubBase+"/profiles/"+(user.profile||"default")+".json", false);
    xhr.send();
    if(xhr.status===200) {
      var pdata = JSON.parse(xhr.responseText);
      var all = (pdata.blocked_domains||[]).concat(pdata.blocked_apps_domains||[]);
      if(all.length===0) { el.innerHTML='<div style="color:#64748b;text-align:center;padding:16px">אין אתרים חסומים</div>'; return; }
      var html = '<table><tr><th>#</th><th>דומיין</th><th>סוג</th></tr>';
      pdata.blocked_domains.forEach(function(d,i){
        html += '<tr><td style="color:#475569">'+(i+1)+'</td><td>'+d+'</td><td><span style="color:#fcd34d;font-size:0.78rem">דפדפן</span></td></tr>';
      });
      pdata.blocked_apps_domains.forEach(function(d,i){
        html += '<tr><td style="color:#475569">'+(pdata.blocked_domains.length+i+1)+'</td><td>'+d+'</td><td><span style="color:#f87171;font-size:0.78rem">אפליקציה</span></td></tr>';
      });
      html += '</table>';
      el.innerHTML = html;
    } else {
      el.innerHTML = '<div style="color:#f87171;text-align:center;padding:16px">שגיאה בטעינת הרשימה</div>';
    }
  } catch(e){ el.innerHTML='<div style="color:#f87171;text-align:center;padding:16px">שגיאה: '+e.message+'</div>'; }
}

function requestUninstall() {
  var reason = document.getElementById('uninstReason').value;
  var el = document.getElementById('uninstStatus');
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    var params = {
      service_id: CFG.ejsService,
      template_id: CFG.ejsTplUninst,
      user_id: CFG.ejsKey,
      template_params: {
        to_email: CFG.adminEmail,
        subject: "בקשת הסרה: " + user.name,
        user_name: user.name,
        user_email: user.email,
        user_phone: user.phone,
        reason: reason || "לא צוינה סיבה",
        request_time: new Date().toLocaleString('he-IL')
      }
    };
    xhr.open("POST","https://api.emailjs.com/api/v1.0/email/send",false);
    xhr.setRequestHeader("Content-Type","application/json");
    xhr.send(JSON.stringify(params));
  } catch(e){}
  el.style.display='block';
  el.innerHTML='<div class="alert warn">⏳ בקשת ההסרה נשלחה למנהל. אנא המתן לאישור.<br><strong>אם לא יאושר, אנא פנה למנהל המערכת.</strong></div>';
  checkUninstallApproval();
}

function checkUninstallApproval() {
  try {
    var xhr = new ActiveXObject("MSXML2.XMLHTTP");
    xhr.open("GET", CFG.githubBase+"/approvals/"+user.email.replace("@","_at_")+".json", false);
    xhr.send();
    if(xhr.status===200) {
      var a = JSON.parse(xhr.responseText);
      if(a.uninstall_approved) {
        document.getElementById('uninstApprovedCard').style.display='block';
      }
    }
  } catch(e){}
}

function doUninstall() {
  if(!confirm("האם אתה בטוח שברצונך להסיר את NetBlocker?")) return;
  try {
    var sh = new ActiveXObject("WScript.Shell");
    sh.Run('powershell -WindowStyle Hidden -ExecutionPolicy Bypass -File "'+CFG.installDir+'\\uninstall.ps1"',0,true);
  } catch(e){}
  alert("NetBlocker הוסר בהצלחה. שלום!");
  window.close();
}
</script>
</body>
</html>
